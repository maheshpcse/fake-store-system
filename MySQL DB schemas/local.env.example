APP_NAME=Fake Store Local API
ENVIRONMENT=local
DATABASE_URL=mysql+pymysql://root:YOUR_MYSQL_PASSWORD@127.0.0.1:3306/fake_store
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AWS_REGION=ap-south-1
S3_BUCKET_NAME=fake-store-payment-files-local
S3_RAW_PREFIX=raw
S3_ARCHIVE_PREFIX=archive
S3_ERROR_PREFIX=error
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_INBOUND_PATH=/inbound
SFTP_ARCHIVE_PATH=/archive
SUPPORTED_CURRENCIES=USD
PAYMENT_AMOUNT_MUST_MATCH_ORDER=true
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:5173
