{
  "FunctionName": "${PROCESSOR_LAMBDA_NAME}",
  "Description": "Validate S3 payment reports, stage rows, promote valid payments, and archive the file.",
  "Runtime": "python3.12",
  "Architectures": [
    "x86_64"
  ],
  "Handler": "app.workers.lambda_handlers.payment_file_processor_handler.lambda_handler",
  "Role": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/${PROCESSOR_LAMBDA_ROLE_NAME}",
  "CodeZipFile": "deployment/lambda/dist/fake-store-payment-processor.zip",
  "MemorySize": 2048,
  "Timeout": 600,
  "EphemeralStorage": {
    "Size": 2048
  },
  "ReservedConcurrentExecutions": 5,
  "TracingConfig": {
    "Mode": "Active"
  },
  "VpcConfig": {
    "SubnetIds": [
      "${PRIVATE_SUBNET_1}",
      "${PRIVATE_SUBNET_2}"
    ],
    "SecurityGroupIds": [
      "${LAMBDA_SECURITY_GROUP_ID}"
    ],
    "Ipv6AllowedForDualStack": false
  },
  "Environment": {
    "Variables": {
      "APP_NAME": "Fake Store Payment Processor",
      "ENVIRONMENT": "production",
      "DATABASE_URL": "${DATABASE_URL_FROM_SECURE_DEPLOYMENT}",
      "S3_BUCKET_NAME": "${S3_BUCKET_NAME}",
      "S3_RAW_PREFIX": "raw",
      "S3_ARCHIVE_PREFIX": "archive",
      "S3_ERROR_PREFIX": "error",
      "SUPPORTED_CURRENCIES": "USD",
      "PAYMENT_AMOUNT_MUST_MATCH_ORDER": "true"
    }
  },
  "LoggingConfig": {
    "LogFormat": "JSON",
    "ApplicationLogLevel": "INFO",
    "SystemLogLevel": "INFO",
    "LogGroup": "/aws/lambda/${PROCESSOR_LAMBDA_NAME}"
  },
  "DeadLetterConfig": {
    "TargetArn": "arn:aws:sqs:${AWS_REGION}:${AWS_ACCOUNT_ID}:${DLQ_NAME}"
  }
}

