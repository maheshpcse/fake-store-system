{
  "service": "Amazon CloudWatch Alarms",
  "alarms": [
    {
      "AlarmName": "${SFTP_LAMBDA_NAME}-errors",
      "Namespace": "AWS/Lambda",
      "MetricName": "Errors",
      "Dimensions": [
        {
          "Name": "FunctionName",
          "Value": "${SFTP_LAMBDA_NAME}"
        }
      ],
      "Statistic": "Sum",
      "Period": 300,
      "EvaluationPeriods": 1,
      "DatapointsToAlarm": 1,
      "Threshold": 1,
      "ComparisonOperator": "GreaterThanOrEqualToThreshold",
      "TreatMissingData": "notBreaching",
      "AlarmActions": [
        "${SNS_ALERT_TOPIC_ARN}"
      ]
    },
    {
      "AlarmName": "${PROCESSOR_LAMBDA_NAME}-errors",
      "Namespace": "AWS/Lambda",
      "MetricName": "Errors",
      "Dimensions": [
        {
          "Name": "FunctionName",
          "Value": "${PROCESSOR_LAMBDA_NAME}"
        }
      ],
      "Statistic": "Sum",
      "Period": 300,
      "EvaluationPeriods": 1,
      "DatapointsToAlarm": 1,
      "Threshold": 1,
      "ComparisonOperator": "GreaterThanOrEqualToThreshold",
      "TreatMissingData": "notBreaching",
      "AlarmActions": [
        "${SNS_ALERT_TOPIC_ARN}"
      ]
    },
    {
      "AlarmName": "${PROCESSOR_LAMBDA_NAME}-duration",
      "Namespace": "AWS/Lambda",
      "MetricName": "Duration",
      "Dimensions": [
        {
          "Name": "FunctionName",
          "Value": "${PROCESSOR_LAMBDA_NAME}"
        }
      ],
      "Statistic": "Maximum",
      "Period": 300,
      "EvaluationPeriods": 1,
      "DatapointsToAlarm": 1,
      "Threshold": 540000,
      "ComparisonOperator": "GreaterThanOrEqualToThreshold",
      "TreatMissingData": "notBreaching",
      "AlarmActions": [
        "${SNS_ALERT_TOPIC_ARN}"
      ]
    }
  ]
}

