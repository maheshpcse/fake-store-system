{
  "service": "AWS Secrets Manager",
  "secrets": [
    {
      "name": "fake-store/prod/database",
      "description": "Fake Store MySQL connection details.",
      "kmsKeyId": "alias/aws/secretsmanager",
      "secretStringTemplate": {
        "engine": "mysql",
        "host": "${RDS_ENDPOINT_OR_MYSQL_HOST}",
        "port": 3306,
        "dbname": "fake_store",
        "username": "${DB_USERNAME}",
        "password": "${DB_PASSWORD}",
        "database_url": "mysql+pymysql://${DB_USERNAME}:${URL_ENCODED_DB_PASSWORD}@${RDS_ENDPOINT_OR_MYSQL_HOST}:3306/fake_store"
      }
    },
    {
      "name": "fake-store/prod/sftp",
      "description": "Fake Store SFTP connection details.",
      "kmsKeyId": "alias/aws/secretsmanager",
      "secretStringTemplate": {
        "host": "${SFTP_HOST}",
        "port": 22,
        "username": "${SFTP_USERNAME}",
        "password": "${SFTP_PASSWORD}",
        "inbound_path": "/inbound",
        "archive_path": "/archive"
      }
    }
  ]
}

